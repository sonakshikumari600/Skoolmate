rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Helper function to get user role
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    // Helper function to check if user is teacher
    function isTeacher() {
      return isSignedIn() && getUserRole() == 'teacher';
    }
    
    // Helper function to check if user is parent
    function isParent() {
      return isSignedIn() && getUserRole() == 'parent';
    }
    
    // Helper function to check if user is student
    function isStudent() {
      return isSignedIn() && getUserRole() == 'student';
    }
    
    // ==================== USERS COLLECTION ====================
    match /users/{userId} {
      // Anyone authenticated can read user profiles
      allow read: if isSignedIn();
      
      // Users can only create their own profile during signup
      allow create: if isSignedIn() && isOwner(userId);
      
      // Users can only update their own profile
      allow update: if isSignedIn() && isOwner(userId);
      
      // Only the user can delete their own profile
      allow delete: if isSignedIn() && isOwner(userId);
    }
    
    // ==================== ATTENDANCE COLLECTION ====================
    match /attendance/{attendanceId} {
      // Students can read their own attendance
      // Parents can read their child's attendance
      // Teachers can read all attendance
      allow read: if isSignedIn() && (
        isTeacher() ||
        isOwner(resource.data.studentId) ||
        (isParent() && resource.data.studentId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.children)
      );
      
      // Only teachers can create attendance records
      allow create: if isSignedIn() && isTeacher() && 
        request.resource.data.keys().hasAll(['studentId', 'classId', 'date', 'status', 'markedBy']);
      
      // Only teachers can update attendance
      allow update: if isSignedIn() && isTeacher();
      
      // Only teachers can delete attendance
      allow delete: if isSignedIn() && isTeacher();
    }
    
    // ==================== HOMEWORK COLLECTION ====================
    match /homework/{homeworkId} {
      // Students can read homework assigned to their class
      // Teachers can read all homework
      // Parents can read homework for their child's class
      allow read: if isSignedIn();
      
      // Only teachers can create homework
      allow create: if isSignedIn() && isTeacher() &&
        request.resource.data.keys().hasAll(['title', 'description', 'classId', 'teacherId', 'dueDate']);
      
      // Only the teacher who created it can update
      allow update: if isSignedIn() && isTeacher() && 
        resource.data.teacherId == request.auth.uid;
      
      // Only the teacher who created it can delete
      allow delete: if isSignedIn() && isTeacher() && 
        resource.data.teacherId == request.auth.uid;
      
      // Homework submissions subcollection
      match /submissions/{studentId} {
        // Students can read their own submissions
        // Teachers can read all submissions
        allow read: if isSignedIn() && (
          isTeacher() ||
          isOwner(studentId)
        );
        
        // Only students can create their own submissions
        allow create: if isSignedIn() && isStudent() && isOwner(studentId);
        
        // Students can update their own submissions before deadline
        allow update: if isSignedIn() && isStudent() && isOwner(studentId);
        
        // Students can delete their own submissions
        allow delete: if isSignedIn() && isStudent() && isOwner(studentId);
      }
    }
    
    // ==================== EXAMS COLLECTION ====================
    match /exams/{examId} {
      // Everyone authenticated can read exams
      allow read: if isSignedIn();
      
      // Only teachers can create exams
      allow create: if isSignedIn() && isTeacher() &&
        request.resource.data.keys().hasAll(['title', 'subject', 'classId', 'examDate', 'totalMarks']);
      
      // Only teachers can update exams
      allow update: if isSignedIn() && isTeacher();
      
      // Only teachers can delete exams
      allow delete: if isSignedIn() && isTeacher();
      
      // Marks subcollection
      match /marks/{studentId} {
        // Students can read their own marks
        // Parents can read their child's marks
        // Teachers can read all marks
        allow read: if isSignedIn() && (
          isTeacher() ||
          isOwner(studentId) ||
          (isParent() && studentId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.children)
        );
        
        // Only teachers can create/update marks
        allow create, update: if isSignedIn() && isTeacher();
        
        // Only teachers can delete marks
        allow delete: if isSignedIn() && isTeacher();
      }
    }
    
    // ==================== NOTIFICATIONS COLLECTION ====================
    match /notifications/{notificationId} {
      // Users can only read their own notifications
      allow read: if isSignedIn() && isOwner(resource.data.userId);
      
      // Teachers and system can create notifications
      allow create: if isSignedIn() && (
        isTeacher() ||
        request.resource.data.userId == request.auth.uid
      );
      
      // Users can update their own notifications (mark as read)
      allow update: if isSignedIn() && isOwner(resource.data.userId);
      
      // Users can delete their own notifications
      allow delete: if isSignedIn() && isOwner(resource.data.userId);
    }
    
    // ==================== MESSAGES COLLECTION ====================
    match /messages/{messageId} {
      // Users can read messages where they are a participant
      allow read: if isSignedIn() && 
        request.auth.uid in resource.data.participants;
      
      // Users can create messages where they are the sender
      allow create: if isSignedIn() && 
        request.auth.uid == request.resource.data.senderId &&
        request.auth.uid in request.resource.data.participants;
      
      // Users can update messages they sent (edit/delete)
      allow update: if isSignedIn() && 
        request.auth.uid == resource.data.senderId;
      
      // Users can delete messages they sent
      allow delete: if isSignedIn() && 
        request.auth.uid == resource.data.senderId;
    }
    
    // ==================== LEAVES COLLECTION ====================
    match /leaves/{leaveId} {
      // Students can read their own leaves
      // Parents can read their child's leaves
      // Teachers can read all leaves
      allow read: if isSignedIn() && (
        isTeacher() ||
        isOwner(resource.data.studentId) ||
        (isParent() && resource.data.studentId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.children)
      );
      
      // Parents and students can create leave applications
      allow create: if isSignedIn() && (
        isParent() || isStudent()
      ) && request.resource.data.keys().hasAll(['studentId', 'startDate', 'endDate', 'reason']);
      
      // Teachers can update leave status (approve/reject)
      // Parents/students can update their own pending leaves
      allow update: if isSignedIn() && (
        isTeacher() ||
        (resource.data.status == 'pending' && (
          isOwner(resource.data.studentId) ||
          (isParent() && resource.data.studentId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.children)
        ))
      );
      
      // Only the applicant can delete pending leaves
      allow delete: if isSignedIn() && 
        resource.data.status == 'pending' && (
          isOwner(resource.data.studentId) ||
          (isParent() && resource.data.studentId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.children)
        );
    }
    
    // ==================== TIMETABLES COLLECTION ====================
    match /timetables/{classId} {
      // Everyone authenticated can read timetables
      allow read: if isSignedIn();
      
      // Only teachers can create/update timetables
      allow create, update: if isSignedIn() && isTeacher();
      
      // Only teachers can delete timetables
      allow delete: if isSignedIn() && isTeacher();
    }
    
    // ==================== FEES COLLECTION ====================
    match /fees/{feeId} {
      // Students can read their own fees
      // Parents can read their child's fees
      // Teachers/admin can read all fees
      allow read: if isSignedIn() && (
        isTeacher() ||
        isOwner(resource.data.studentId) ||
        (isParent() && resource.data.studentId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.children)
      );
      
      // Only teachers/admin can create fee records
      allow create: if isSignedIn() && isTeacher();
      
      // Teachers can update fees
      // Parents can update payment status
      allow update: if isSignedIn() && (
        isTeacher() ||
        (isParent() && resource.data.studentId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.children)
      );
      
      // Only teachers can delete fee records
      allow delete: if isSignedIn() && isTeacher();
    }
    
    // ==================== CLASSES COLLECTION ====================
    match /classes/{classId} {
      // Everyone authenticated can read classes
      allow read: if isSignedIn();
      
      // Only teachers can create classes
      allow create: if isSignedIn() && isTeacher();
      
      // Only teachers can update classes
      allow update: if isSignedIn() && isTeacher();
      
      // Only teachers can delete classes
      allow delete: if isSignedIn() && isTeacher();
    }
    
    // ==================== EVENTS COLLECTION ====================
    match /events/{eventId} {
      // Everyone authenticated can read events
      allow read: if isSignedIn();
      
      // Only teachers can create events
      allow create: if isSignedIn() && isTeacher();
      
      // Only teachers can update events
      allow update: if isSignedIn() && isTeacher();
      
      // Only teachers can delete events
      allow delete: if isSignedIn() && isTeacher();
    }
    
    // ==================== ANNOUNCEMENTS COLLECTION ====================
    match /announcements/{announcementId} {
      // Everyone authenticated can read announcements
      allow read: if isSignedIn();
      
      // Only teachers can create announcements
      allow create: if isSignedIn() && isTeacher();
      
      // Only teachers can update announcements
      allow update: if isSignedIn() && isTeacher();
      
      // Only teachers can delete announcements
      allow delete: if isSignedIn() && isTeacher();
    }
    
    // ==================== STUDENT PROFILES COLLECTION ====================
    match /studentProfiles/{studentId} {
      // Students can read their own profile
      // Parents can read their child's profile
      // Teachers can read all student profiles
      allow read: if isSignedIn() && (
        isTeacher() ||
        isOwner(studentId) ||
        (isParent() && studentId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.children)
      );
      
      // Teachers can create student profiles
      allow create: if isSignedIn() && isTeacher();
      
      // Teachers and students can update profiles
      allow update: if isSignedIn() && (
        isTeacher() ||
        isOwner(studentId)
      );
      
      // Only teachers can delete student profiles
      allow delete: if isSignedIn() && isTeacher();
    }
    
    // ==================== TEACHER PROFILES COLLECTION ====================
    match /teacherProfiles/{teacherId} {
      // Everyone authenticated can read teacher profiles
      allow read: if isSignedIn();
      
      // Teachers can create their own profile
      allow create: if isSignedIn() && isTeacher() && isOwner(teacherId);
      
      // Teachers can update their own profile
      allow update: if isSignedIn() && isTeacher() && isOwner(teacherId);
      
      // Teachers can delete their own profile
      allow delete: if isSignedIn() && isTeacher() && isOwner(teacherId);
    }
    
    // ==================== PARENT PROFILES COLLECTION ====================
    match /parentProfiles/{parentId} {
      // Parents can read their own profile
      // Teachers can read all parent profiles
      allow read: if isSignedIn() && (
        isTeacher() ||
        isOwner(parentId)
      );
      
      // Parents can create their own profile
      allow create: if isSignedIn() && isParent() && isOwner(parentId);
      
      // Parents can update their own profile
      allow update: if isSignedIn() && isParent() && isOwner(parentId);
      
      // Parents can delete their own profile
      allow delete: if isSignedIn() && isParent() && isOwner(parentId);
    }
    
    // ==================== DEFAULT DENY ====================
    // Deny all other requests by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
